{
  "name": "backend",
  "version": "1.5.0",
  "main": "src/app.ts",
  "scripts": {
    "dev": "ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "vitest --exclude **/*.integration.test.ts",
    "dev:setup": "npm-run-all -s db:dev:up db:dev:wait db:migrate dev",
    "db:dev:up": "docker-compose -f docker-compose.yml up -d",
    "db:dev:down": "docker-compose -f docker-compose.yml down",
    "db:dev:wait": "dotenv -e .env -- node scripts/waitForDb.js",
    "db:migrate": "dotenv -e .env -- npx prisma migrate dev --name init",
    "db:test:up": "docker-compose -f docker-compose.test.yml up -d",
    "db:test:down": "docker-compose -f docker-compose.test.yml down",
    "db:test:wait": "dotenv -e .env.test -- node scripts/waitForDb.js",
    "test:integration:run": "dotenv -e .env.test -- npx prisma generate && dotenv -e .env.test -- npx prisma db push --force-reset && dotenv -e .env.test -- vitest run **/*.integration.test.ts",
    "test:integration": "npm-run-all -s db:test:up db:test:wait test:integration:run db:test:down"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^3.0.0",
    "axios": "^1.6.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^17.2.3",
    "express": "^4.17.1",
    "jsonwebtoken": "^9.0.2",
    "openapi-types": "^12.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "dotenv-cli": "^7.4.2",
    "npm-run-all": "^4.1.5",
    "prisma": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5",
    "vitest": "^3.2.4"
  }
}
